# =============================================================================
# PromiseLink PoC 环境变量模板
# =============================================================================
# 使用方法：
#   1. 复制本文件为 .env.poc
#      cp .env.poc.example .env.poc
#   2. 填入实际值（标记为 [必填] 的项必须配置）
#   3. 启动服务
#      docker compose -f docker-compose.poc.yml up -d
#
# 安全提醒：
#   - .env.poc 已被 .gitignore 排除，不会被提交到版本库
#   - 切勿将含真实密钥的文件提交到 Git
# =============================================================================

# ---- 应用基础配置 ----

# 运行阶段标识 [无需修改]
APP_ENV=poc

# ---- 数据库配置 ----

# 数据库连接 URL
# PoC 阶段使用 SQLite：
DATABASE_URL=sqlite:///./data/promiselink_poc.db
# Phase 1 阶段使用 PostgreSQL（取消注释下行，注释上行）：
# DATABASE_URL=postgresql+asyncpg://promiselink:promiselink_dev@postgres:5432/promiselink

# 应用密钥，用于 JWT 签名等安全场景 [必填]
# 生成方法：python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=

# ---- LLM 配置（云端 API）----

# LLM API Key [必填]
# 支持 OpenAI / Anthropic / Moka AI 等，填入对应平台的 API Key
LLM_API_KEY=

# LLM API Base URL [必填]
# OpenAI:        https://api.openai.com/v1
# Anthropic:     https://api.anthropic.com
# Moka AI:       https://api.moka-ai.com/v1
# 其他兼容接口：  填入对应的 Base URL
LLM_BASE_URL=

# LLM 模型名称 [按需修改]
# OpenAI:      gpt-4 / gpt-4o / gpt-4o-mini
# Anthropic:   claude-sonnet-4-20250514 / claude-3-5-haiku-20241022
LLM_MODEL=gpt-4

# LLM 请求超时时间（秒）[按需修改]
LLM_TIMEOUT=30

# LLM 请求最大重试次数 [按需修改]
LLM_MAX_RETRIES=3

# ---- Redis 配置 ----

# Redis 连接 URL [按需修改]
REDIS_URL=redis://redis:6379/0

# 是否启用 Redis [按需修改]
# PoC 阶段默认不启用，Phase 1 阶段建议启用
REDIS_ENABLED=false

# ---- 应用基础配置（续）----

# 日志级别：DEBUG / INFO / WARNING / ERROR [按需修改]
# PoC 阶段建议 INFO，排查问题时可临时切换为 DEBUG
LOG_LEVEL=INFO

# CORS 允许的来源地址 [按需修改]
# 微信小程序开发工具：http://localhost:3000
# 本地前端开发：      http://localhost:5173
# 多个来源用 JSON 数组格式，例如：["http://localhost:3000","http://localhost:5173"]
CORS_ORIGINS=http://localhost:3000

# ---- 微信小程序配置 (Phase 1) ----

# 微信小程序 AppID [按需配置]
WECHAT_APP_ID=
# 微信小程序 AppSecret [按需配置]
WECHAT_APP_SECRET=
