# =============================================================================
# PromiseLink PoC 环境变量模板
# =============================================================================
# 许可证：本项目采用 MPL 2.0 开源许可证，商业使用需遵守许可证条款。
# 详见项目根目录 LICENSE 文件或 https://www.mozilla.org/en-US/MPL/2.0/
# =============================================================================
# 使用方法：
#   1. 复制本文件为 .env.poc
#      cp .env.poc.example .env.poc
#   2. 填入实际值（标记为 [必填] 的项必须配置）
#   3. 启动服务
#      docker compose -f docker-compose.poc.yml up -d
#
# 安全提醒：
#   - .env.poc 已被 .gitignore 排除，不会被提交到版本库
#   - 切勿将含真实密钥的文件提交到 Git
# =============================================================================

# ---- 应用基础配置 ----

# 运行阶段标识 [无需修改]
APP_ENV=poc

# ---- 数据库配置 ----

# 数据库连接 URL
# PoC 阶段使用 SQLite：
DATABASE_URL=sqlite:///./data/promiselink_poc.db
# Phase 1 阶段使用 PostgreSQL（取消注释下行，注释上行）：
# 注意：密码通过 PG_PASSWORD 环境变量注入，请勿硬编码（P1-6 安全修复）
# DATABASE_URL=postgresql+asyncpg://promiselink:${PG_PASSWORD}@postgres:5432/promiselink

# PostgreSQL 密码 [必填]（docker-compose.poc.yml 的 postgres 服务需要，即使用 SQLite 也需设置）
# 生成方法：python -c "import secrets; print(secrets.token_urlsafe(24))"
PG_PASSWORD=

# 应用密钥，用于 JWT 签名等安全场景 [必填]
# 生成方法：python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=

# PoC 访问密码 [建议修改]
# 默认密码为 promiselink2026，请尽快修改为你自己的密码
POC_SECRET=promiselink2026

# ---- LLM 配置（云端 API）----

# LLM Provider [可选]
# 可选值：moka_ai（默认）、openai、anthropic
# 设置后，LLM_BASE_URL 和 LLM_MODEL 会自动填充对应预设值（也可手动覆盖）
# LLM_PROVIDER=moka_ai

# LLM API Key [必填]
# 支持 Moka AI / OpenAI / Anthropic 等，填入对应平台的 API Key
LLM_API_KEY=

# LLM API Base URL [可选]
# 设置 LLM_PROVIDER 后会自动填充，也可手动覆盖
# Moka AI:    https://api.moka-ai.com/v1
# OpenAI:     https://api.openai.com/v1
# Anthropic:  https://api.anthropic.com/v1
LLM_BASE_URL=

# LLM 模型名称 [可选]
# 设置 LLM_PROVIDER 后会自动填充，也可手动覆盖
# Moka AI:    moka/claude-sonnet-4-6
# OpenAI:     gpt-5.5
# Anthropic:  claude-sonnet-4-6-20250514
LLM_MODEL=

# LLM 请求超时时间（秒）[按需修改]
LLM_TIMEOUT=30

# LLM 请求最大重试次数 [按需修改]
LLM_MAX_RETRIES=3

# ---- Redis 配置 ----

# Redis 连接 URL [按需修改]
REDIS_URL=redis://redis:6379/0

# 是否启用 Redis [按需修改]
# PoC 阶段默认不启用，Phase 1 阶段建议启用
REDIS_ENABLED=false

# ---- 应用基础配置（续）----

# 日志级别：DEBUG / INFO / WARNING / ERROR [按需修改]
# PoC 阶段建议 INFO，排查问题时可临时切换为 DEBUG
LOG_LEVEL=INFO

# CORS 允许的来源地址 [按需修改]
# 微信小程序开发工具：http://localhost:3000
# 本地前端开发：      http://localhost:5173
# 多个来源用 JSON 数组格式，例如：["http://localhost:3000","http://localhost:5173"]
CORS_ORIGINS=http://localhost:3000

# ---- 微信小程序配置 (Phase 1) ----

# 微信小程序 AppID [按需配置]
WECHAT_APP_ID=
# 微信小程序 AppSecret [按需配置]
WECHAT_APP_SECRET=
