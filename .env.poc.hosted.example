# PromiseLink Hosted PoC Environment Variables
# Copy this file to .env.poc.hosted and fill in your values

APP_ENV=production
DATABASE_URL=sqlite:///./data/promiselink_poc.db
SECRET_KEY=  # REQUIRED: Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
LOG_LEVEL=INFO
POC_SECRET=  # REQUIRED: Set a password for PoC login
LLM_API_KEY=  # REQUIRED: Your LLM API key
LLM_BASE_URL=https://api.moka-ai.com/v1
LLM_MODEL=moka/claude-sonnet-4-6
LLM_TIMEOUT=30
LLM_MAX_RETRIES=3
CORS_ORIGINS=["https://your-domain.com"]
