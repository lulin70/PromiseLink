# =============================================================================
# PromiseLink 基础版 配置
# =============================================================================
# 许可证：本项目采用 GNU AGPL v3 开源许可证，商业使用需遵守许可证条款。
# 详见项目根目录 LICENSE 文件或 https://www.gnu.org/licenses/agpl-3.0.html
# =============================================================================
# 使用方法：
#   1. 复制本文件为 .env.basic
#      cp .env.basic.example .env.basic
#   2. 填入实际值（标记为 [必填] 的项必须配置）
#   3. 启动服务
#      docker compose -f docker-compose.basic.yml up -d
#
# 安全提醒：
#   - .env.basic 已被 .gitignore 排除，不会被提交到版本库
#   - 切勿将含真实密钥的文件提交到 Git
# =============================================================================

# ---- LLM 配置（云端 API）----

# LLM Provider [可选]
# 可选值：moka_ai（默认）、openai、anthropic
# 设置后，LLM_BASE_URL 和 LLM_MODEL 会自动填充对应预设值（也可手动覆盖）
LLM_PROVIDER=moka_ai

# LLM API Key [必填]
# PromiseLink 需要 LLM 来提取实体、识别承诺、生成建议等
#
# 推荐方案（按性价比排序）：
#   1. Moka AI — 注册 https://moka-ai.com ，支持 Claude 系列模型
#      LLM_PROVIDER=moka_ai
#      LLM_API_KEY=sk-xxx
#      LLM_BASE_URL=https://api.moka-ai.com/v1
#      LLM_MODEL=moka/claude-sonnet-4-6
#
#   2. OpenAI — 注册 https://platform.openai.com
#      LLM_PROVIDER=openai
#      LLM_API_KEY=sk-xxx
#      LLM_BASE_URL=https://api.openai.com/v1
#      LLM_MODEL=gpt-5.5
#
#   3. Anthropic — 注册 https://console.anthropic.com
#      LLM_PROVIDER=anthropic
#      LLM_API_KEY=sk-xxx
#      LLM_BASE_URL=https://api.anthropic.com/v1
#      LLM_MODEL=claude-sonnet-4-6-20250514
#
#   4. DeepSeek — 注册 https://platform.deepseek.com ，新用户有免费额度
#      LLM_API_KEY=sk-xxx
#      LLM_BASE_URL=https://api.deepseek.com/v1
#      LLM_MODEL=deepseek-chat
#
# 费用参考：单次事件录入约消耗 2000-4000 tokens，日均10条交互约 ¥0.1-0.5
#
LLM_API_KEY=sk-your-key-here

# LLM API Base URL [可选]
# 设置 LLM_PROVIDER 后会自动填充，也可手动覆盖
# LLM_BASE_URL=https://api.moka-ai.com/v1

# LLM 模型名称 [可选]
# 设置 LLM_PROVIDER 后会自动填充，也可手动覆盖
# LLM_MODEL=moka/claude-sonnet-4-6

# ---- 安全配置 ----

# 应用密钥 [必填]
# 用于 JWT 签名，请修改为随机字符串
# 生成方法：python -c "import secrets; print(secrets.token_urlsafe(32))"
# ⚠️ 如不设置，开发环境会自动生成随机密钥（重启后 token 失效）
SECRET_KEY=change-me-in-production

# PoC 访问密码 [建议修改]
# 默认密码为 promiselink2026，请尽快修改为你自己的密码
POC_SECRET=promiselink2026

# ---- 数据库配置 ----

# 数据库路径（容器内路径，一般不需要修改）
# DATABASE_URL=sqlite:///./data/promiselink.db

# ---- 应用配置 ----

# 日志级别 [可选]
# LOG_LEVEL=INFO

# CORS 允许的来源地址 [可选]
# CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# Edition: basic (基础版) or pro (专业版)
# APP_EDITION=basic
