# =============================================================================
# PromiseLink 基础版 配置
# =============================================================================
# 使用方法：
#   1. 复制本文件为 .env.basic
#      cp .env.basic.example .env.basic
#   2. 填入实际值（标记为 [必填] 的项必须配置）
#   3. 启动服务
#      docker compose -f docker-compose.basic.yml up -d
#
# 安全提醒：
#   - .env.basic 已被 .gitignore 排除，不会被提交到版本库
#   - 切勿将含真实密钥的文件提交到 Git
# =============================================================================

# ---- LLM 配置（云端 API）----

# LLM API Key [必填]
# PromiseLink 需要 LLM 来提取实体、识别承诺、生成建议等
#
# 推荐方案（按性价比排序）：
#   1. DeepSeek — 注册 https://platform.deepseek.com ，新用户有免费额度
#      LLM_API_KEY=sk-xxx
#      LLM_BASE_URL=https://api.deepseek.com/v1
#      LLM_MODEL=deepseek-chat
#
#   2. Moka AI — 注册 https://moka-ai.com ，支持 Claude 系列模型
#      LLM_API_KEY=sk-xxx
#      LLM_BASE_URL=https://api.moka-ai.com/v1
#      LLM_MODEL=moka/claude-sonnet-4-6
#
#   3. OpenAI — 注册 https://platform.openai.com
#      LLM_API_KEY=sk-xxx
#      LLM_BASE_URL=https://api.openai.com/v1
#      LLM_MODEL=gpt-4o-mini
#
# 费用参考：单次事件录入约消耗 2000-4000 tokens，日均10条交互约 ¥0.1-0.5
#
LLM_API_KEY=sk-your-key-here

# LLM API Base URL [可选]
# 默认为 https://api.moka-ai.com/v1
LLM_BASE_URL=https://api.moka-ai.com/v1

# LLM 模型名称 [可选]
# 默认为 moka/claude-sonnet-4-6
LLM_MODEL=moka/claude-sonnet-4-6

# ---- 安全配置 ----

# 应用密钥 [必填]
# 用于 JWT 签名等安全场景，请修改为随机字符串
# 生成方法：python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-to-a-random-string

# PoC 访问密码 [可选]
# 不设则无需密码即可访问
# POC_SECRET=promiselink2024

# ---- 数据库配置 ----

# 数据库路径（容器内路径，一般不需要修改）
# DATABASE_URL=sqlite:///./data/promiselink.db

# ---- 应用配置 ----

# 日志级别 [可选]
# LOG_LEVEL=INFO

# CORS 允许的来源地址 [可选]
# CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
