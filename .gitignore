# PromiseLink .gitignore

# === Secrets & Credentials ===
.env
.env.*
!.env.poc.example
!.env.basic.example
!.env.poc.hosted.example
*.key
*.pem
*.p12
credentials.json
secrets.yaml

# === API Keys (any file containing keys) ===
**/api_keys*
**/config.local*

# === Data & Cache ===
data/
llm_cache/
*.db
*.db-shm
*.db-wal
*.sqlite3

# === Python ===
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/
*.egg
.venv/
venv/
env/
.Python

# === IDE ===
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# === DevSquad runtime ===
.mas_v3_*/
checkpoint_*/
scratchpad_*/

# === Internal docs (sensitive) ===
docs/internal/
archive/

# === Logs ===
*.log
logs/

# === Temporary files ===
*.tmp
*.bak
*_draft.*
*_old.*
*_tmp.*

# === Node.js ===
node_modules/

# === Compressed archives ===
*.tar.gz
*.zip

# === External docs binary assets ===
docs/external/**/*.png
docs/external/**/*.xlsx
docs/external/**/*.pptx

# === Frontend build cache ===
frontend/.swc/
frontend/dist/

# === Test coverage ===
.coverage
htmlcov/
.pytest_cache/
.ruff_cache/
.mypy_cache/
