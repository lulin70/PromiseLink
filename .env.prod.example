# =============================================================================
# PromiseLink 生产/Staging 环境配置模板
# =============================================================================
# 使用方法：
#   1. 复制本文件为 .env.prod
#      cp .env.prod.example .env.prod
#   2. 填入实际值（标记为 [必填] 的项必须配置）
#   3. 部署
#      VERSION=0.8.0 docker compose -f docker-compose.prod.yml up -d
#
# 安全提醒：
#   - .env.prod 已被 .gitignore 排除，不会被提交到版本库
#   - 切勿将含真实密钥的文件提交到 Git
#   - 生产环境 SECRET_KEY 和 POC_SECRET 必须使用强随机值
# =============================================================================

# ---- 应用环境 ----
APP_ENV=production

# ---- 数据库 ----
# docker-compose.prod.yml 内部使用 /app/data/promiselink.db
#DATABASE_URL=sqlite+aiosqlite:////app/data/promiselink.db

# ---- 安全配置 ----

# 应用密钥 [必填]
# 用于 JWT 签名，必须使用强随机字符串
# 生成方法：python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE_ME_GENERATE_WITH_secrets_token_urlsafe_32

# PoC 访问密码 [必填]
# 生成方法：python -c "import secrets; print(secrets.token_urlsafe(16))"
POC_SECRET=CHANGE_ME_GENERATE_WITH_secrets_token_urlsafe_16

# ---- LLM 配置 ----

# LLM Provider [可选]
# 可选值：moka_ai（默认）、openai、anthropic
LLM_PROVIDER=moka_ai

# LLM API Key [必填]
LLM_API_KEY=sk-your-key-here

# LLM 超时与重试（LLM 调用较慢时需增大）
LLM_TIMEOUT=60
LLM_MAX_RETRIES=5
LLM_MAX_TOKENS=4000

# ---- 日志 ----
LOG_LEVEL=INFO

# ---- CORS ----
# 生产环境填实际域名
CORS_ORIGINS=["https://www.promiselink.cn","https://promiselink.cn"]

# ---- 应用版本 ----
# Edition: basic (基础版) or pro (专业版)
APP_EDITION=basic
